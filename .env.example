# Database
DATABASE_URL=postgresql://user:password@localhost:5432/campanhas_eleitorais
DB_HOST=localhost
DB_PORT=5432
DB_USER=campanhas_user
DB_PASSWORD=secure_password_123
DB_NAME=campanhas_eleitorais

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key
